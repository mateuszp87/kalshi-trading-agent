# ── Required ──────────────────────────────────────────────────────────────────
KALSHI_API_KEY=your_kalshi_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Kalshi endpoint (default = live trading; use demo for paper trading) ──────
# KALSHI_BASE_URL=https://demo-api.kalshi.co/trade-api/v2   # paper trading
KALSHI_BASE_URL=https://trading-api.kalshi.com/trade-api/v2

# ── Sports ─────────────────────────────────────────────────────────────────────
# The Odds API — https://the-odds-api.com/ (free tier: 500 req/month)
ESPN_API_KEY=your_the_odds_api_key_here

# ── Politics / Entertainment ───────────────────────────────────────────────────
# NewsAPI — https://newsapi.org/ (free tier: 100 req/day)
NEWSAPI_KEY=your_newsapi_key_here

# ── Economics ──────────────────────────────────────────────────────────────────
# FRED — https://fred.stlouisfed.org/docs/api/api_key.html (free)
FRED_API_KEY=your_fred_api_key_here

# ── Crypto ─────────────────────────────────────────────────────────────────────
# CoinGecko — https://www.coingecko.com/api (free tier available)
COINGECKO_API_KEY=your_coingecko_api_key_here

# ── Weather ────────────────────────────────────────────────────────────────────
# NOAA CDO — https://www.ncdc.noaa.gov/cdo-web/token (free)
NOAA_TOKEN=your_noaa_token_here
